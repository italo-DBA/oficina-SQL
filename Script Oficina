-- Queries 

/*Qual o valor total de mão de obra por OS, apenas para as que custam mais de R$ 500,00?
Utiliza: SELECT, JOIN, Atributo Derivado (SUM), GROUP BY e HAVING.*/

SELECT 
    os.id_os, 
    v.modelo AS Carro,
    SUM(s.valor_mao_de_obra) AS Total_Mao_Obra
FROM OrdemServico os
JOIN Veiculo v ON os.id_veiculo = v.id_veiculo
JOIN OS_Servicos oss ON os.id_os = oss.id_os
JOIN Servico s ON oss.id_servico = s.id_servico
GROUP BY os.id_os
HAVING Total_Mao_Obra > 500.00
ORDER BY Total_Mao_Obra DESC;

/*Listar Clientes, seus veículos e os mecânicos responsáveis pelo conserto.
Utiliza: Múltiplas junções (perspectiva complexa).*/

SELECT 
    c.nome AS Cliente,
    v.modelo AS Veiculo,
    os.id_os AS Numero_OS,
    m.nome AS Mecanico_Responsavel,
    m.especialidade
FROM Cliente c
JOIN Veiculo v ON c.id_cliente = v.id_cliente
JOIN OrdemServico os ON v.id_veiculo = os.id_veiculo
JOIN Equipe e ON os.id_equipe = e.id_equipe
JOIN Mecanico m ON e.id_equipe = m.id_equipe;

/*Qual a média de dias para conclusão de uma OS por equipe?
Utiliza: DATEDIFF (Atributo derivado), WHERE e ORDER BY.*/

SELECT 
    e.nome_equipe,
    ROUND(AVG(DATEDIFF(os.data_conclusao, os.data_emissao)), 2) AS Media_Dias_Conserto
FROM OrdemServico os
JOIN Equipe e ON os.id_equipe = e.id_equipe
WHERE os.status = 'Concluída'
GROUP BY e.id_equipe
ORDER BY Media_Dias_Conserto ASC;
